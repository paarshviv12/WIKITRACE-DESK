    {
      "type": "text",
      "id": "t-15",
      "x": 1415.5003706429966,
      "y": 777.1225081442788,
      "width": 800.7997436523438,
      "height": 315,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
