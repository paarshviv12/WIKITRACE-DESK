      "seed": 438989806,
      "version": 220,
      "versionNonce": 1013166996,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782066603118,
      "link": null,
      "locked": false,
      "fontSize": 28,
      "fontFamily": 8,
      "text": "\n- Regex pathfinder ORs all doc IDs into one pattern,\n  scans each body, then traces the connection trail.\n- SHA-256 via crypto.subtle.digest on the file\n  ArrayBuffer -> integrity hash logged per scan.\n- Text pulled with Mammoth.js (DOCX) & PDF.js (PDF).\n\nAll parsing, hashing & mapping run 100% in-browser:\n  zero backend, zero cloud, zero data leakage.",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\n- Regex pathfinder ORs all doc IDs into one pattern,\n  scans each body, then traces the connection trail.\n- SHA-256 via crypto.subtle.digest on the file\n  ArrayBuffer -> integrity hash logged per scan.\n- Text pulled with Mammoth.js (DOCX) & PDF.js (PDF).\n\nAll parsing, hashing & mapping run 100% in-browser:\n  zero backend, zero cloud, zero data leakage.",
      "lineHeight": 1.25,
      "baseline": 13,
      "index": "aE",
      "autoResize": true
    },
    {
      "type": "rectangle",
