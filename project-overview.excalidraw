    {
      "type": "text",
      "id": "t-9",
      "x": 1144.3146659672432,
      "y": 149.01670291940766,
      "width": 818.0343447527634,
      "height": 319.5747979737331,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 1801823909,
      "version": 567,
      "versionNonce": 1503404491,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782066368277,
      "link": null,
      "locked": false,
      "fontSize": 23.2418034889988,
      "fontFamily": 8,
      "text": "1. Library ......... in-memory indexed state   (DocumentLibrary)\n2. DOCX Reader ..... Mammoth.js  XML -> text     (LeftSidebar)\n3. PDF Reader ...... PDF.js render context       (LeftSidebar)\n4. Citation Map .... directed graph G = (V,E)    (CitationMap)\n5. Path Finder ..... regex reference matcher     (FullGraphView)\n6. Audit Log ....... SHA-256 Web Crypto API      (RightSidebar)\n7. Word Export ..... DOCX builder + Gmail draft  (RightSidebar)\n8. Desk Landing .... LED / keyboard simulation   (landing.html)\n\nEvery concern lives in its OWN component. Navbar + App.jsx\nwire state, theme & layout;  CSS handles the glass UI.",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Library ......... in-memory indexed state   (DocumentLibrary)\n2. DOCX Reader ..... Mammoth.js  XML -> text     (LeftSidebar)\n3. PDF Reader ...... PDF.js render context       (LeftSidebar)\n4. Citation Map .... directed graph G = (V,E)    (CitationMap)\n5. Path Finder ..... regex reference matcher     (FullGraphView)\n6. Audit Log ....... SHA-256 Web Crypto API      (RightSidebar)\n7. Word Export ..... DOCX builder + Gmail draft  (RightSidebar)\n8. Desk Landing .... LED / keyboard simulation   (landing.html)\n\nEvery concern lives in its OWN component. Navbar + App.jsx\nwire state, theme & layout;  CSS handles the glass UI.",
      "lineHeight": 1.25,
      "baseline": 13,
      "index": "a8",
      "autoResize": true
    },
