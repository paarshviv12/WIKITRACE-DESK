    {
      "type": "text",
      "id": "t-6",
      "x": -299.86214355002335,
      "y": 79.17053082213965,
      "width": 654.9922079368869,
      "height": 248.10310906700255,
      "angle": 0,
      "strokeColor": "#1e1e1e",
